# HOÀNG GIA PHỞ → RideNDine payment proxy — Vercel env vars
# Set these in Vercel → Project Settings → Environment Variables (NOT in the repo).

# Shared secret issued by RideNDine (must equal RideNDine's PARTNER_API_KEY).
# SECRET — server-side only, never ships to the browser.
RIDENDINE_PARTNER_API_KEY=

# RideNDine's deployed base URL (no trailing slash), e.g. https://app.ridendine.com
RIDENDINE_WEB_BASE=

# NOTE: RideNDine's Stripe PUBLISHABLE key (pk_live_…) is set directly in
# checkout.html (RIDENDINE_STRIPE_PUBLISHABLE_KEY). Publishable keys are public.
