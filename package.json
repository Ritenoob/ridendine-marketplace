{
  "name": "@ridendine/monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@ridendine/web",
    "dev:chef": "turbo dev --filter=@ridendine/chef-admin",
    "dev:ops": "turbo dev --filter=@ridendine/ops-admin",
    "dev:driver": "turbo dev --filter=@ridendine/driver-app",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && node -e \"require('node:fs').rmSync('node_modules',{recursive:true,force:true})\"",
    "db:generate": "turbo db:generate --filter=@ridendine/db",
    "db:migrate": "supabase db push",
    "db:seed": "supabase db seed",
    "db:reset": "supabase db reset",
    "local-cron": "node scripts/local-cron.mjs",
    "verify:prod-data-hygiene": "node scripts/verify-prod-data-hygiene.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "test": "pnpm -r --if-present test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:smoke": "playwright test --grep @smoke",
    "test:load": "node scripts/load/run-load-smoke.mjs",
    "test:load:dry-run": "node scripts/load/run-load-smoke.mjs --dry-run",
    "tools:ensure": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/tools/ensure-node-pnpm.ps1",
    "smoke:prod": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/smoke/production-smoke.ps1",
    "release:verify": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/release/verify-release.ps1",
    "admin:bootstrap-super": "node scripts/bootstrap-super-admin.mjs",
    "smoke:prod:contracts": "node scripts/smoke/runtime-contract-smoke.cjs",
    "smoke:driver-shift-mutation": "node scripts/smoke/driver-shift-mutation-smoke.cjs",
    "smoke:live-role-fixture": "node scripts/smoke/live-role-fixture-smoke.cjs",
    "smoke:non-admin-role-fixture": "node scripts/smoke/non-admin-role-fixture-smoke.cjs",
    "smoke:non-admin-role-readiness": "node scripts/smoke/non-admin-role-fixture-smoke.cjs --preflight --require-all-roles",
    "smoke:surface-classification": "node scripts/smoke/runtime-surface-classification.cjs",
    "smoke:runtime-coverage": "node scripts/smoke/runtime-coverage-audit.cjs",
    "smoke:proof-disposition": "node scripts/smoke/runtime-proof-disposition.cjs",
    "smoke:ops-export-audit": "node scripts/smoke/ops-export-audit-smoke.cjs",
    "smoke:proof-actions": "node scripts/smoke/runtime-proof-action-smoke.cjs",
    "smoke:sample-fixtures": "node scripts/smoke/runtime-sample-fixtures.cjs",
    "smoke:responsive": "node scripts/smoke/responsive-production-smoke.cjs",
    "audit:ops-authz": "node scripts/audit/high-risk-ops-authz-contracts.cjs",
    "audit:ops-negative-authz": "node scripts/audit/high-risk-ops-negative-authz.cjs",
    "audit:sean-super-admin": "node scripts/audit/sean-super-admin-fixture.cjs",
    "audit:db-hardening": "node scripts/audit/verify-db-hardening.mjs",
    "audit:db-boundary": "node scripts/audit/db-boundary-ratchet.mjs",
    "ui:screenshots": "tsx scripts/ui/generate-ui-screenshots.ts",
    "ui:registry": "tsx scripts/ui/build-page-registry.ts",
    "ui:screenshots:sync": "tsx scripts/ui/sync-ui-screenshots.ts",
    "ui:docs": "tsx scripts/ui/generate-command-center-docs.ts",
    "ui:command-center": "pnpm ui:registry && pnpm ui:screenshots:sync && pnpm ui:docs",
    "docs:obsidian-architecture": "powershell -ExecutionPolicy Bypass -File scripts/docs/generate-obsidian-architecture.ps1",
    "docs:api-guard-snapshot": "powershell -ExecutionPolicy Bypass -File scripts/docs/generate-api-guard-snapshot.ps1",
    "docs:wiring": "node scripts/wiring/generate-wiring-docs.cjs && pnpm smoke:surface-classification -- --write-docs && pnpm smoke:runtime-coverage -- --write-docs && pnpm smoke:proof-disposition -- --write-docs && pnpm smoke:non-admin-role-fixture -- --contracts-only --write-docs && pnpm docs:supabase",
    "docs:supabase": "node scripts/wiring/generate-supabase-diagrams.cjs",
    "test:wiring-fixes": "node scripts/wiring/verify-known-wiring-fixes.cjs && node --test scripts/smoke/runtime-contract-smoke.test.cjs scripts/smoke/live-role-fixture-smoke.test.cjs scripts/smoke/non-admin-role-fixture-smoke.test.cjs scripts/smoke/runtime-surface-classification.test.cjs scripts/smoke/runtime-coverage-audit.test.cjs scripts/smoke/runtime-proof-disposition.test.cjs scripts/smoke/ops-export-audit-smoke.test.cjs scripts/smoke/runtime-proof-action-smoke.test.cjs scripts/smoke/runtime-sample-fixtures.test.cjs scripts/smoke/driver-shift-mutation-smoke.test.cjs scripts/smoke/production-smoke.test.cjs scripts/smoke/responsive-production-smoke.test.cjs scripts/audit/sean-super-admin-fixture.test.cjs scripts/audit/high-risk-ops-authz-contracts.test.cjs scripts/audit/high-risk-ops-negative-authz.test.cjs",
    "audit:guards": "node scripts/audit/check-api-route-guards.mjs",
    "e2e:validate-seed": "node scripts/e2e/validate-seed-uuids.mjs",
    "test:e2e:setup": "supabase db reset && pnpm db:seed",
    "test:e2e:lifecycle:fixtures": "node scripts/e2e/verify-lifecycle-fixtures.mjs",
    "test:e2e:lifecycle:reset": "node scripts/e2e/reset-live-fixtures.mjs",
    "test:e2e:lifecycle": "pnpm test:e2e:lifecycle:fixtures && playwright test e2e/lifecycle --project=web-smoke"
  },
  "dependencies": {
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.55.1",
    "@types/node": "^20.17.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "pg": "^8.20.0",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tsx": "^4.19.2",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.58.0",
    "wait-on": "^8.0.0"
  }
}
