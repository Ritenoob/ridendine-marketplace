# ===========================================
# RIDENDINE ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env.local (per app or repo root) and fill in your values.
# NEVER commit real credentials to version control.
#
# Canonical matrix: docs/ENVIRONMENT_VARIABLES.md
# Deployment order: docs/RUNBOOK_DEPLOY.md

# Node (usually set by host; local override optional)
# NODE_ENV=development

# Supabase Configuration
# Get these from your Supabase project dashboard: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Database (for migrations/direct access)
# Get from Supabase: Settings > Database > Connection string
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# Application URLs (adjust for production)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CHEF_ADMIN_URL=http://localhost:3001
# Required for Stripe Connect onboarding return URLs in chef-admin (must match this app's public URL)
# Optional override for chef signup CTAs (defaults to NEXT_PUBLIC_CHEF_ADMIN_URL/auth/signup)
# NEXT_PUBLIC_CHEF_PORTAL_SIGNUP_URL=http://localhost:3001/auth/signup
NEXT_PUBLIC_DRIVER_APP_URL=http://localhost:3003
# Customer web app URL for cross-app links (defaults to NEXT_PUBLIC_APP_URL semantics)
# NEXT_PUBLIC_WEB_URL=http://localhost:3000

# Stripe Configuration
# Get from Stripe Dashboard: Developers > API keys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Separate webhook signing secret for the ops-admin Stripe webhook endpoint
STRIPE_WEBHOOK_SECRET_OPS=whsec_your_ops_webhook_secret
# Allow sk_test_ keys while NODE_ENV=production (staging/smoke only — never enable on real prod)
# STRIPE_ALLOW_TEST_IN_PRODUCTION=false

# Google Maps (for delivery tracking)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key

# Cron / scheduled jobs (local dev: any string; production: rotate)
CRON_SECRET=

# Email delivery (Resend) — optional; falls back to DB notifications when unset
RESEND_API_KEY=

# SMS delivery (Twilio) — optional; falls back to DB notifications when unset
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Engine Processor Authentication
# Used by automated SLA and expired-offer processors
# Legacy fallback alongside CRON_SECRET Bearer pattern
# Generate with: openssl rand -hex 32
ENGINE_PROCESSOR_TOKEN=

# Deterministic lifecycle e2e fixture reset endpoint (non-production only)
E2E_FIXTURE_RESET_ENABLED=false

# Error Monitoring (Sentry)
# Create a project at sentry.io and paste the DSN here
# NEXT_PUBLIC_SENTRY_DSN=https://your-key@o123.ingest.sentry.io/456

# Web push notifications (driver app / web) — VAPID public key
# Generate a pair with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key

# Internal ops command-center surface (ops-admin) — keep disabled outside internal envs
# INTERNAL_COMMAND_CENTER_ENABLED=false

# Super-admin bootstrap (scripts/bootstrap-super-admin.mjs)
# BOOTSTRAP_SUPER_ADMIN_PASSWORD=choose_a_strong_password

# Production smoke-test credentials (scripts/smoke/*) — override the built-in fixture account
# RIDENDINE_SMOKE_EMAIL=smoke-user@example.com
# RIDENDINE_SMOKE_PASSWORD=smoke_password

# Development autologin shortcut (local dev only — never honored in production)
ALLOW_DEV_AUTOLOGIN=false

# --- Optional (see docs/ENVIRONMENT_VARIABLES.md) ---
# Rate limiting (production): Upstash Redis — omit in dev to use in-memory fallback where applicable
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Deployment / health checks
# APP_ENV=staging
# LOG_LEVEL=info
# CHECKOUT_IDEMPOTENCY_MIGRATION_APPLIED=true

# Load testing (scripts/load/run-load-smoke.mjs)
# LOAD_BASE_URL=http://localhost:3000
# LOAD_ITERATIONS=40
# LOAD_CONCURRENCY=8
